# Copy this file to .env and fill in real values. .env is gitignored.

# Neon Postgres. Use the POOLED connection string for DATABASE_URL
# (required on Vercel serverless — see PRD 8.1) and the DIRECT
# (unpooled) connection string for DIRECT_URL, which Prisma uses
# to run migrations.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/assesstrack?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/assesstrack?sslmode=require"

# Random secret used to sign clinician auth JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=""

# Used once by `npx prisma db seed` to create the single clinician
# login. Not read at runtime — safe to remove from .env after seeding.
SEED_CLINICIAN_EMAIL=""
SEED_CLINICIAN_PASSWORD=""
SEED_CLINICIAN_NAME=""

# Resend (resend.com) — sends reminder emails for overdue assessments.
RESEND_API_KEY=""
# Optional. Defaults to Resend's shared test domain (no DNS setup
# needed). Switch to a verified custom domain once you have one:
# RESEND_FROM_EMAIL="ClinTrack <reminders@yourdomain.com>"
RESEND_FROM_EMAIL=""

# Verifies that /api/cron/reminders is only triggered by Vercel Cron,
# not by anyone who guesses the URL. Vercel automatically sends this
# as a Bearer token when the cron fires, once you set the same value
# in your Vercel project's environment variables. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=""
